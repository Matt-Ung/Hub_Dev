\@writefile{lof}{\contentsline {figure}{\numberline {Figure 7.1}{\ignorespaces Archived broad-pilot ranking. This figure is used here as a descriptive development artifact: it shows which intervention families separated from the baseline strongly enough to justify follow-up study, but it is not treated as a thesis-grade estimate of general effectiveness.}}{25}{figure.7.1}\protected@file@percent }
\newlabel{fig:broad-repaired-ranking}{{Figure 7.1}{25}{Archived broad-pilot ranking. This figure is used here as a descriptive development artifact: it shows which intervention families separated from the baseline strongly enough to justify follow-up study, but it is not treated as a thesis-grade estimate of general effectiveness}{figure.7.1}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {7.1.1}Broad Coverage Pilot}{25}{subsection.7.1.1}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {Figure 7.2}{\ignorespaces Archived decoder-depth ranking over the stripped and packed \texttt  {config\_decoder\_test} variants. This case study is stronger than the broad pilot because it includes repeated runs, but it still remains a developmental case study rather than the final held-out evaluation.}}{26}{figure.7.2}\protected@file@percent }
\newlabel{fig:decoder-depth-ranking}{{Figure 7.2}{26}{Archived decoder-depth ranking over the stripped and packed \texttt {config\_decoder\_test} variants. This case study is stronger than the broad pilot because it includes repeated runs, but it still remains a developmental case study rather than the final held-out evaluation}{figure.7.2}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {7.1.2}Focused Decoder-Depth Case Study}{26}{subsection.7.1.2}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {Figure 7.3}{\ignorespaces Archived decoder-depth reliability and coverage. This figure is especially important because it separates weak analytical output from a validator-dominated failure mode.}}{27}{figure.7.3}\protected@file@percent }
\newlabel{fig:decoder-depth-reliability}{{Figure 7.3}{27}{Archived decoder-depth reliability and coverage. This figure is especially important because it separates weak analytical output from a validator-dominated failure mode}{figure.7.3}{}}
\@writefile{toc}{\contentsline {section}{\numberline {7.2}Final Held-Out Evaluation}{27}{section.7.2}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {Figure 7.4}{\ignorespaces Repaired final held-out ranking across the seven maintained configurations. This figure uses the rebuilt repaired experiment so that all configurations have full coverage. The highest descriptive mean score belongs to \texttt  {worker\_prompt\_shape:artifact\_focused}, but none of the overall shifts reached the thesis confidence target of $p \le 0.05$.}}{28}{figure.7.4}\protected@file@percent }
\newlabel{fig:final-overall-ranking}{{Figure 7.4}{28}{Repaired final held-out ranking across the seven maintained configurations. This figure uses the rebuilt repaired experiment so that all configurations have full coverage. The highest descriptive mean score belongs to \texttt {worker\_prompt\_shape:artifact\_focused}, but none of the overall shifts reached the thesis confidence target of $p \le 0.05$}{figure.7.4}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {7.2.1}Overall Performance After Recovery}{28}{subsection.7.2.1}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {Figure 7.5}{\ignorespaces Effect-size summary for the repaired final held-out comparison relative to baseline. This figure matters because the repaired experiment supports descriptive ranking, but the inferential question is whether any overall shift is large and stable enough to treat as more than a sample-limited difference.}}{29}{figure.7.5}\protected@file@percent }
\newlabel{fig:final-effect-size-summary}{{Figure 7.5}{29}{Effect-size summary for the repaired final held-out comparison relative to baseline. This figure matters because the repaired experiment supports descriptive ranking, but the inferential question is whether any overall shift is large and stable enough to treat as more than a sample-limited difference}{figure.7.5}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {Figure 7.6}{\ignorespaces Cross-executable score-delta heatmap for the repaired final held-out experiment. Positive cells indicate improvement over the baseline on that executable and negative cells indicate degradation. This view matters because every non-baseline configuration in the repaired final run is marked as mixed and masked by average in the executable-consistency summary.}}{30}{figure.7.6}\protected@file@percent }
\newlabel{fig:final-cross-executable-heatmap}{{Figure 7.6}{30}{Cross-executable score-delta heatmap for the repaired final held-out experiment. Positive cells indicate improvement over the baseline on that executable and negative cells indicate degradation. This view matters because every non-baseline configuration in the repaired final run is marked as mixed and masked by average in the executable-consistency summary}{figure.7.6}{}}
