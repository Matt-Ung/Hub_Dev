{
  "schema_version": "launch_preset_v3",
  "name": "budget_best_value_r2",
  "description": "Recommended under-budget study for decision-useful comparisons. Same scope as the r1 version, but with two repetitions for stronger comparisons.",
  "runner": "sweep",
  "corpus": "experimental",
  "samples": [
    "config_decoder_test.exe",
    "signal_router_report_test.exe",
    "stack_notice_scheduler_test.exe",
    "hash_dispatch_test.exe",
    "embedded_payload_test_upx.exe",
    "maintenance_orchestrator_test.exe",
    "branch_weave_snapshot_test.exe"
  ],
  "tasks": [
    "config_value_recovery",
    "routing_behavior_recovery",
    "decoy_string_audit",
    "hash_mapping_recovery",
    "packing_tool_triage",
    "decoy_signal_audit",
    "program_decode_recovery"
  ],
  "repetitions": 2,
  "label": "budget-best-value",
  "max_run_estimated_cost_usd": 2.5,
  "max_experiment_estimated_cost_usd": 20.0,
  "skip_visuals": false,
  "recommended_judge_model": "openai:gpt-4o-mini",
  "baseline": {
    "corpus": "experimental",
    "pipeline": "auto_triage",
    "architecture": "balanced",
    "query_variant": "default",
    "subagent_profile": "default",
    "worker_persona_profile": "default",
    "worker_role_prompt_mode": "default",
    "validator_review_level": "default",
    "tool_profile": "full",
    "model_profile": "repo_default",
    "force_model": "",
    "judge_mode": "agent"
  },
  "model_profiles": {
    "repo_default": {
      "description": "Use the repo defaults with no forced override.",
      "force_model": ""
    }
  },
  "sweeps": [
    {
      "variable": "tool_availability",
      "description": "Disable selected MCP tool families while keeping the baseline pipeline, architecture, and prompt shape fixed.",
      "variants": [
        {
          "name": "core_static",
          "overrides": {
            "tool_profile": "core_static"
          }
        },
        {
          "name": "ghidra_only",
          "overrides": {
            "tool_profile": "ghidra_only"
          }
        }
      ]
    },
    {
      "variable": "architecture_preset",
      "description": "Swap only the worker architecture preset while keeping the baseline pipeline and query shape fixed.",
      "variants": [
        {
          "name": "minimal",
          "overrides": {
            "architecture": "minimal"
          }
        },
        {
          "name": "ghidra_focused",
          "overrides": {
            "architecture": "ghidra_focused"
          }
        },
        {
          "name": "model_augmented",
          "overrides": {
            "architecture": "model_augmented"
          }
        }
      ]
    },
    {
      "variable": "worker_subagents",
      "description": "Reduce worker specialist breadth to a single generalist slot while leaving the rest of the workflow unchanged.",
      "variants": [
        {
          "name": "single_generalist",
          "overrides": {
            "subagent_profile": "single_generalist"
          }
        }
      ]
    }
  ]
}
