{
  "schema_version": "launch_preset_v3",
  "name": "thesis_final_eval_r3_100usd",
  "description": "Thesis-grade final-round evaluation over the five opaque final_round binaries. Locks the task surface to blind default_analysis and spends the remaining budget on a broad but interpretable configuration comparison set.",
  "runner": "sweep",
  "corpus": "final_round",
  "samples": [
    "sample1.exe",
    "sample2.exe",
    "sample3.exe",
    "sample4.exe",
    "sample5.exe"
  ],
  "tasks": [
    "default_analysis"
  ],
  "repetitions": 3,
  "label": "thesis-final-eval-r3",
  "prefer_upx_unpacked": true,
  "task_failure_retries": 1,
  "max_run_estimated_cost_usd": 4.0,
  "hard_max_run_estimated_cost_usd": 6.0,
  "max_experiment_estimated_cost_usd": 100.0,
  "hard_max_experiment_estimated_cost_usd": 120.0,
  "skip_visuals": false,
  "recommended_judge_model": "openai:gpt-4o-mini",
  "baseline": {
    "corpus": "final_round",
    "pipeline": "auto_triage",
    "architecture": "balanced",
    "response_scope_variant": "default",
    "analysis_hint_variant": "default",
    "subagent_profile": "default",
    "worker_persona_profile": "default",
    "worker_role_prompt_mode": "default",
    "validator_review_level": "default",
    "tool_profile": "full",
    "model_profile": "repo_default",
    "force_model": "",
    "judge_mode": "agent"
  },
  "model_profiles": {
    "repo_default": {
      "description": "Use the repo defaults with no forced override.",
      "force_model": ""
    },
    "budget": {
      "description": "Force the cheaper cross-run model profile if a lower-cost pilot is needed.",
      "force_model": "openai:gpt-5-nano"
    },
    "premium": {
      "description": "Force the stronger cross-run model profile used in maintained sweeps.",
      "force_model": "openai:gpt-5-mini"
    }
  },
  "sweeps": [
    {
      "variable": "worker_subagents",
      "description": "Compare the locked final baseline against the single-generalist worker profile.",
      "variants": [
        {
          "name": "single_generalist",
          "overrides": {
            "subagent_profile": "single_generalist"
          }
        }
      ]
    },
    {
      "variable": "worker_prompt_shape",
      "description": "Compare the locked final baseline against the most informative prompt-shape follow-ups from development sweeps.",
      "variants": [
        {
          "name": "artifact_focused",
          "overrides": {
            "worker_persona_profile": "artifact_focused",
            "worker_role_prompt_mode": "default"
          }
        },
        {
          "name": "empty",
          "overrides": {
            "worker_persona_profile": "default",
            "worker_role_prompt_mode": "blank"
          }
        }
      ]
    },
    {
      "variable": "response_scope",
      "description": "Compare the locked final baseline against the concise response-scope follow-up that moved positively in the broad pilot without leaking new sample-specific hints.",
      "variants": [
        {
          "name": "brief",
          "overrides": {
            "response_scope_variant": "brief"
          }
        }
      ]
    },
    {
      "variable": "architecture_preset",
      "description": "Compare the locked final baseline against the two architecture variants that add the most interpretable diversity.",
      "variants": [
        {
          "name": "ghidra_focused",
          "overrides": {
            "architecture": "ghidra_focused"
          }
        },
        {
          "name": "model_augmented",
          "overrides": {
            "architecture": "model_augmented"
          }
        }
      ]
    }
  ]
}
