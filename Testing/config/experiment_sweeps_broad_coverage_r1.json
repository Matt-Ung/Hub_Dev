{
  "version": "binary_experiment_sweep_broad_coverage_r1",
  "description": "One-repetition broad-coverage sweep for the experimental corpus. This extends the maintained default sweep with selected extra architecture, pipeline, and model-profile coverage to maximize decision-useful breadth. The historical `60usd` preset name is retained for compatibility, but under the current 0.50-per-sample-task heuristic this plan projects well above 60 USD.",
  "repetitions": 1,
  "baseline": {
    "corpus": "experimental",
    "pipeline": "auto_triage",
    "architecture": "balanced",
    "query_variant": "default",
    "subagent_profile": "default",
    "worker_persona_profile": "default",
    "worker_role_prompt_mode": "default",
    "validator_review_level": "default",
    "tool_profile": "full",
    "model_profile": "repo_default",
    "force_model": "",
    "judge_mode": "agent"
  },
  "model_profiles": {
    "repo_default": {
      "description": "Use the repo's mixed per-stage and per-role model defaults with no forced override.",
      "force_model": ""
    },
    "budget": {
      "description": "Force the cheapest cross-run model profile used in experiments. This changes model choice, not token budgets or runtime limits.",
      "force_model": "openai:gpt-5-nano"
    },
    "premium": {
      "description": "Force the stronger cross-run model profile used in experiments. This changes model choice, not token budgets or runtime limits.",
      "force_model": "openai:gpt-5-mini"
    }
  },
  "sweeps": [
    {
      "variable": "query_verbosity",
      "description": "Change only the task prompt/query detail level with a shorter-than-default query variant.",
      "variants": [
        {
          "name": "brief",
          "overrides": {
            "query_variant": "brief"
          }
        }
      ]
    },
    {
      "variable": "worker_subagents",
      "description": "Reduce worker specialist breadth to a single generalist slot while leaving the rest of the workflow unchanged.",
      "variants": [
        {
          "name": "single_generalist",
          "overrides": {
            "subagent_profile": "single_generalist"
          }
        }
      ]
    },
    {
      "variable": "worker_prompt_shape",
      "description": "Compare the maintained default worker prompts against an evidence-first overlay and an empty worker-role condition while keeping worker breadth, tools, and pipeline constant.",
      "variants": [
        {
          "name": "artifact_focused",
          "overrides": {
            "worker_persona_profile": "artifact_focused",
            "worker_role_prompt_mode": "default"
          }
        },
        {
          "name": "empty",
          "overrides": {
            "worker_persona_profile": "default",
            "worker_role_prompt_mode": "blank"
          }
        }
      ]
    },
    {
      "variable": "tool_availability",
      "description": "Disable selected MCP tool families while keeping the baseline pipeline, architecture, and prompt shape fixed.",
      "variants": [
        {
          "name": "core_static",
          "overrides": {
            "tool_profile": "core_static"
          }
        },
        {
          "name": "ghidra_only",
          "overrides": {
            "tool_profile": "ghidra_only"
          }
        }
      ]
    },
    {
      "variable": "architecture_preset",
      "description": "Selected worker-architecture study that keeps one lean variant and one Ghidra-centric variant beyond the balanced default.",
      "variants": [
        {
          "name": "minimal",
          "overrides": {
            "architecture": "minimal"
          }
        },
        {
          "name": "ghidra_focused",
          "overrides": {
            "architecture": "ghidra_focused"
          }
        }
      ]
    },
    {
      "variable": "pipeline_preset",
      "description": "Broader pipeline study spanning no-preflight, validator-light, medium-validator, and dual-validator worker flows.",
      "variants": [
        {
          "name": "workers_reporter",
          "overrides": {
            "pipeline": "preflight_planner_workers_reporter"
          }
        },
        {
          "name": "planner_workers_reporter",
          "overrides": {
            "pipeline": "planner_workers_reporter"
          }
        },
        {
          "name": "planner_workers_light_validators_reporter",
          "overrides": {
            "pipeline": "planner_workers_light_validators_reporter"
          }
        },
        {
          "name": "planner_workers_validators_reporter",
          "overrides": {
            "pipeline": "planner_workers_validators_reporter"
          }
        },
        {
          "name": "planner_workers_dual_validators_reporter",
          "overrides": {
            "pipeline": "planner_workers_dual_validators_reporter"
          }
        }
      ]
    },
    {
      "variable": "model_profile",
      "description": "Compare the repo-default model routing against cheaper and stronger forced-model profiles.",
      "variants": [
        {
          "name": "budget",
          "overrides": {
            "model_profile": "budget"
          }
        },
        {
          "name": "premium",
          "overrides": {
            "model_profile": "premium"
          }
        }
      ]
    },
    {
      "variable": "validator_topology",
      "description": "Change only the validator topology while holding validator review strictness fixed at the family baseline.",
      "baseline_overrides": {
        "pipeline": "preflight_planner_workers_validators_reporter",
        "validator_review_level": "default"
      },
      "variants": [
        {
          "name": "light",
          "overrides": {
            "pipeline": "preflight_planner_workers_light_validators_reporter"
          }
        },
        {
          "name": "dual",
          "overrides": {
            "pipeline": "preflight_planner_workers_dual_validators_reporter"
          }
        }
      ]
    },
    {
      "variable": "validator_review_level",
      "description": "Change only validator strictness while keeping validator topology fixed at the standard single-validator pipeline.",
      "baseline_overrides": {
        "pipeline": "preflight_planner_workers_validators_reporter",
        "validator_review_level": "default"
      },
      "variants": [
        {
          "name": "easy",
          "overrides": {
            "validator_review_level": "easy"
          }
        },
        {
          "name": "intermediate",
          "overrides": {
            "validator_review_level": "intermediate"
          }
        },
        {
          "name": "strict",
          "overrides": {
            "validator_review_level": "strict"
          }
        }
      ]
    }
  ]
}
