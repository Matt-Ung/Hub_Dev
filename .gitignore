# =========================
# Build outputs
# =========================

# Maven build output (any module)
**/target/

# Compiled class files
*.class

# Native / compiled binary outputs
*.exe
*.dll
*.pdb
*.so
*.dylib
*.out

# Logs
*.log
logs/

# Java crash logs (if any)
hs_err_pid*
replay_pid*

# =========================
# Python artifacts
# =========================
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
ENV/
env/

# Test / typecheck / lint caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# =========================
# IDE / editor files
# =========================

# IntelliJ
.idea/
*.iml
*.iws
out/

# Eclipse
.project
.classpath
.settings/
bin/

# VS Code
.vscode/

# Vim / swap / backup files
*.swp
*.swo
*~
.*.swp
.*.swo

# =========================
# OS junk
# =========================

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Thumbnails / metadata
._*
.Spotlight-V100
.Trashes

# =========================
# Tooling / env
# =========================

# Maven Wrapper
.mvn/
!/.mvn/wrapper/maven-wrapper.jar
mvnw
mvnw.cmd

# Environment files
.env
.env.*
.python-version
.direnv/

# =========================
# Third-party binaries
# =========================

# Third party JAR files from Ghidra (any module)
**/lib/*.jar

# =========================
# Project-specific generated/vendor content
# =========================

.deep_backend/
In_Progress/*
MCPServers/capa-rules
MCPServers/capa-sigs
mcp-security-hub
vagrantProjects
third_party/signature-base/

# Generated agent/tool reports: keep helper scripts, ignore emitted artifacts.
agent_artifacts/reports/

Testing/generated/
Testing/build/
Testing/reference_binaries/

# Track docs/templates under Testing/results, ignore generated outputs by default.
Testing/results/*
!Testing/results/README.md
!Testing/results/run_record_template.md
!Testing/results/reference_examples/
!Testing/results/reference_examples/README.md
